---
import { categories } from '../data/categories';
import { prompts } from '../data/prompts';
const trending = prompts.filter((p) => p.trending).slice(0, 4);
---

<aside class="space-y-8">
  <div class="rounded-lg border border-white/5 bg-white/3 p-5">
    <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-mute font-mono">Categories</h3>
    <nav class="space-y-1.5" aria-label="Blog categories">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-body transition-colors hover:text-canvas hover:bg-white/5"
        >
          <span aria-hidden="true">{cat.icon}</span>
          {cat.name}
        </a>
      ))}
    </nav>
  </div>

  <div class="rounded-lg border border-white/5 bg-white/3 p-5">
    <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-mute font-mono">Featured Prompts</h3>
    <nav class="space-y-2" aria-label="Featured prompts">
      {trending.map((p) => (
        <a
          href={`/prompts/${p.slug}`}
          class="block rounded-lg px-3 py-2 text-sm text-body transition-colors hover:text-canvas hover:bg-white/5"
        >
          <span class="line-clamp-1">{p.title}</span>
        </a>
      ))}
    </nav>
  </div>
</aside>
