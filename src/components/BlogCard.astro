---
import type { BlogPost } from '../data/blog';
export interface Props {
  post: BlogPost;
}
const { post } = Astro.props;
---

<article class="group rounded-lg border border-white/5 bg-white/3 p-5 transition-all duration-300 card-hover sm:p-6">
  <div class="flex items-center gap-2 text-xs text-mute font-mono">
    <time datetime={post.date}>{post.date}</time>
    <span aria-hidden="true">·</span>
    <span>{post.readingTime}</span>
  </div>

  <h3 class="mt-3 text-lg font-semibold text-canvas">
    <a href={`/blog/${post.slug}`} class="transition-colors hover:text-link">
      {post.title}
    </a>
  </h3>

  <p class="mt-2 text-sm text-body leading-relaxed">
    {post.excerpt}
  </p>

  <div class="mt-4 flex flex-wrap items-center gap-1.5">
    {post.tags.map((tag) => (
      <span class="inline-flex rounded-full bg-white/5 px-2 py-0.5 text-[10px] font-medium text-mute font-mono">
        #{tag}
      </span>
    ))}
  </div>

  <a
    href={`/blog/${post.slug}`}
    class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-link transition-colors hover:text-link-deep"
  >
    Read more
    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
  </a>
</article>
