---
import type { Prompt } from '../data/prompts';
import PromptCard from './PromptCard.astro';

export interface Props {
  prompts: Prompt[];
}

const { prompts: items } = Astro.props;
---

{items.length > 0 ? (
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((prompt) => (
      <PromptCard prompt={prompt} />
    ))}
  </div>
) : (
  <div class="rounded-lg border border-white/5 bg-white/3 p-12 text-center">
    <p class="text-body">No prompts found in this category yet.</p>
  </div>
)}
