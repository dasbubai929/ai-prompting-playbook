---
import type { PromptCode } from '../data/prompt-codes';

export interface Props {
  code: PromptCode;
}

const { code } = Astro.props;
const copyText = `${code.title}\n\n${code.description}\n\nExample: ${code.exampleUsage}`;
---

<article
  class="code-card group relative rounded-lg border border-white/5 bg-white/3 p-5 sm:p-6 transition-all duration-300 card-hover"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="text-base font-semibold text-canvas font-mono">
        {code.title}
      </h3>
      <p class="mt-1.5 text-xs text-body leading-relaxed">
        {code.description}
      </p>
    </div>

    <button
      class="code-copy-btn shrink-0 flex items-center gap-1.5 rounded-pill-sm border border-white/10 px-3 py-1.5 text-xs font-medium text-body transition-all duration-200 hover:border-link/50 hover:text-link hover:bg-link/5"
      data-prompt={copyText}
      aria-label={`Copy ${code.title} prompt code`}
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      Copy
    </button>
  </div>

  <!-- Expandable example section -->
  <details class="mt-3 group/details">
    <summary class="flex cursor-pointer items-center gap-1.5 text-xs font-medium text-mute transition-colors hover:text-link select-none">
      <svg class="h-3 w-3 transition-transform duration-200 group-open/details:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      Example Usage
    </summary>
    <div class="mt-2 rounded-md border border-white/5 bg-white/3 px-3 py-2.5">
      <code class="text-xs text-link font-mono leading-relaxed">{code.exampleUsage}</code>
    </div>
  </details>

  <div class="mt-3 flex flex-wrap items-center gap-1.5">
    {code.tags.map((tag) => (
      <span class="inline-flex rounded-full bg-white/5 px-2 py-0.5 text-[10px] font-medium text-mute font-mono">
        #{tag}
      </span>
    ))}
  </div>
</article>

<script>
  document.querySelectorAll('.code-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-prompt');
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerHTML;
        btn.innerHTML = '<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
        btn.classList.add('text-success', 'border-success/30', 'hover:text-success');
        setTimeout(() => {
          btn.innerHTML = orig;
          btn.classList.remove('text-success', 'border-success/30', 'hover:text-success');
        }, 2000);
      } catch { /* clipboard not available */ }
    });
  });
</script>
