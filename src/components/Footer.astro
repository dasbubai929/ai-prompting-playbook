---
const footerLinks = [
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Use' },
];

const categories = [
  { href: '/category/hr-recruiting', label: 'HR & Recruiting' },
  { href: '/category/digital-marketing', label: 'Digital Marketing' },
  { href: '/category/course-creators', label: 'Course Creators' },
  { href: '/category/seo-content', label: 'SEO & Content' },
  { href: '/category/saas-dev', label: 'SaaS & Dev' },
];
---

<footer class="border-t border-white/5">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-lg font-semibold">
          <span class="mesh-gradient inline-block h-6 w-6 rounded-md"></span>
          <span>AI Prompting Playbook</span>
        </a>
        <p class="mt-3 text-sm text-mute leading-relaxed max-w-xs">
          Enterprise-grade AI prompts across every niche. Search, copy, and deploy with confidence.
        </p>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-mute font-mono">Quick Links</h3>
        <ul class="space-y-2.5">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-body transition-colors hover:text-canvas">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-mute font-mono">Categories</h3>
        <ul class="space-y-2.5">
          {categories.map((cat) => (
            <li>
              <a href={cat.href} class="text-sm text-body transition-colors hover:text-canvas">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-mute font-mono">Connect</h3>
        <p class="text-sm text-body leading-relaxed">
          Have a suggestion?<br />
          <a href="/contact" class="text-link transition-colors hover:text-link-deep">
            Get in touch
          </a>
        </p>
      </div>
    </div>

    <div class="mt-12 border-t border-white/5 pt-6 text-center text-xs text-mute">
      &copy; {new Date().getFullYear()} AI Prompting Playbook. All rights reserved.
    </div>
  </div>
</footer>
