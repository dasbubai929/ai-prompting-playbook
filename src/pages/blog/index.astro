---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog';
import BlogCard from '../../components/BlogCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { SITE_URL } from '../../consts';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'AI Prompting Playbook Blog',
  description: 'Prompt engineering insights, tutorials, and best practices.',
  url: `${SITE_URL}/blog`,
});
---

<Layout
  title="Blog"
  description="Prompt engineering insights, tutorials, and best practices for AI prompt crafting."
  canonical={`${SITE_URL}/blog`}
  schema={schema}
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <span class="inline-block rounded-full bg-violet/20 px-3 py-1 text-xs font-medium text-violet-soft font-mono">Blog</span>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">Prompt Engineering Insights</h1>
      <p class="mt-2 text-sm text-body">Tutorials, guides, and deep dives into the art of prompt engineering</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_300px]">
      <div class="space-y-4">
        {blogPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
      <Sidebar />
    </div>
  </div>
</Layout>
