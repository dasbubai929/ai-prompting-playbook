---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog';
import Sidebar from '../../components/Sidebar.astro';
import { marked } from 'marked';
import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const related = blogPosts.filter((bp) => bp.id !== post.id).slice(0, 3);

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.date,
  author: { '@type': 'Organization', name: post.author },
  url: `${SITE_URL}/blog/${post.slug}`,
});
---

<Layout
  title={post.title}
  description={post.excerpt}
  canonical={`${SITE_URL}/blog/${post.slug}`}
  schema={schema}
  ogType="article"
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <nav class="mb-8 text-sm">
      <a href="/" class="text-body transition-colors hover:text-canvas">Home</a>
      <span class="mx-2 text-mute">/</span>
      <a href="/blog" class="text-body transition-colors hover:text-canvas">Blog</a>
      <span class="mx-2 text-mute">/</span>
      <span class="text-mute">{post.title}</span>
    </nav>

    <div class="grid gap-8 lg:grid-cols-[1fr_300px]">
      <article>
        <div class="mb-8">
          <div class="flex items-center gap-2 text-xs text-mute font-mono">
            <time datetime={post.date}>{post.date}</time>
            <span aria-hidden="true">·</span>
            <span>{post.readingTime}</span>
          </div>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">{post.title}</h1>
          <p class="mt-3 text-base text-body">{post.excerpt}</p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {post.tags.map((tag) => (
              <span class="inline-flex rounded-full bg-white/5 px-2.5 py-1 text-[11px] font-medium text-mute font-mono">#{tag}</span>
            ))}
          </div>
        </div>

        <div class="prose prose-invert prose-sm sm:prose-base max-w-none">
          <Fragment set:html={marked.parse(post.content)} />
        </div>
      </article>

      <Sidebar />
    </div>

    {related.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-xl font-semibold tracking-tight">More Articles</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((rp) => (
            <a
              href={`/blog/${rp.slug}`}
              class="group rounded-lg border border-white/5 bg-white/3 p-5 transition-all duration-300 card-hover"
            >
              <div class="text-xs text-mute font-mono">{rp.date}</div>
              <h3 class="mt-2 text-sm font-semibold text-canvas group-hover:text-link transition-colors">{rp.title}</h3>
              <p class="mt-1 text-xs text-body line-clamp-2">{rp.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
