---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { prompts } from "../../data/prompts"

export function getStaticPaths() {
  return prompts.map(p => ({
    params: { slug: p.id },
    props: { prompt: p },
  }))
}

const { prompt } = Astro.props
---
<BaseLayout title={prompt.title}>
  <main id="content">
    <section class="section prompt-header">
      <div class="container">
        <p class="eyebrow">{prompt.niche}</p>
        <h1>{prompt.title}</h1>
        <div class="prompt-tags">
          {prompt.tags.map(t => <span class="tag">{t}</span>)}
        </div>
        <p class="prompt-desc">{prompt.desc}</p>
      </div>
    </section>
    <section class="section prompt-text">
      <div class="container">
        <pre class="prompt-code">{prompt.text}</pre>
      </div>
    </section>
  </main>
</BaseLayout>
