---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { prompts, categories } from "../../data/prompts"

export function getStaticPaths() {
  return categories.filter(c => c.id !== "all").map(c => ({
    params: { category: c.id },
    props: { catId: c.id, catLabel: c.label },
  }))
}

const { catId, catLabel } = Astro.props
const filtered = prompts.filter(p => p.cat === catId)
---
<BaseLayout title={catLabel + " Prompts"}>
  <main id="content">
    <section class="section category-header">
      <div class="container">
        <h1>{catLabel}</h1>
        <p class="lead">Browse prompts for {catLabel} workflows and tasks.</p>
      </div>
    </section>
    <section class="section prompts-section">
      <div class="container">
        <div class="prompts-grid">
          {filtered.map(p => (
            <article class="prompt-card">
              <div class="prompt-tags">
                <span class="tag highlight">{p.niche}</span>
                {p.tags.map(t => <span class="tag">{t}</span>)}
              </div>
              <h2 class="prompt-title">{p.title}</h2>
              <p class="prompt-desc">{p.desc}</p>
              <div class="prompt-footer">
                <span class="prompt-updated">{p.updated}</span>
                <a href={"/prompt/" + p.id} class="btn btn-secondary">View Details</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
